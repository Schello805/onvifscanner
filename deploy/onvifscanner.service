[Unit]
Description=ONVIFscanner (Next.js)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=onvifscanner
Group=onvifscanner
WorkingDirectory=/opt/onvifscanner
EnvironmentFile=/etc/onvifscanner/onvifscanner.env
ExecStart=/usr/local/bin/onvifscanner-start
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/onvifscanner

[Install]
WantedBy=multi-user.target

